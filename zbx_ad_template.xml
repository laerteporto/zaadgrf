      <discovery_rules>
        <discovery_rule>
          <uuid>9e69872a9bf54bfeb2c5c203a499301f</uuid>
          <name>Discovery - Domain Controllers</name>
          <type>DEPENDENT</type>
          <key>ad.discovery.dcs</key>
          <delay>0</delay>
          <preprocessing>
            <step>
              <type>JAVASCRIPT</type>
              <parameters>
                <parameter>var data = JSON.parse(value).domain_controllers;
return JSON.stringify(data.map(function(dc){
  return {
    "{#DC_NAME}": dc.name,
    "{#DC_HOST}": dc.hostname,
    "{#DC_SITE}": dc.site,
    "{#DC_IP}": dc.ip_address
  };
}));</parameter>
              </parameters>
            </step>
          </preprocessing>
          <master_item>
            <key>ad.monitor.data</key>
          </master_item>
          <item_prototypes>
            <item_prototype>
              <uuid>4432c74af45a4d6da71ab7dc1bb138a2</uuid>
              <name>DC {#DC_NAME} - Reachable</name>
              <type>DEPENDENT</type>
              <key>ad.dc.reachable[{#DC_HOST}]</key>
              <delay>0</delay>
              <history>7d</history>
              <value_type>UNSIGNED</value_type>
              <preprocessing>
                <step>
                  <type>JSONPATH</type>
                  <parameters>
                    <parameter>$.domain_controllers[?(@.hostname=='{#DC_HOST}')].reachable.first()</parameter>
                  </parameters>
                </step>
                <step>
                  <type>BOOL_TO_DECIMAL</type>
                  <parameters/>
                </step>
              </preprocessing>
              <master_item>
                <key>ad.monitor.data</key>
              </master_item>
              <trigger_prototypes>
                <trigger_prototype>
                  <uuid>78686a6baf4346578a9ff59e619b2f9f</uuid>
                  <expression>last(/AD Health Monitoring/ad.dc.reachable[{#DC_HOST}])=0</expression>
                  <name>Domain Controller {#DC_NAME} unreachable</name>
                  <priority>DISASTER</priority>
                </trigger_prototype>
              </trigger_prototypes>
            </item_prototype>
            <item_prototype>
              <uuid>3736c8936334477391326bc482cc281c</uuid>
              <name>DC {#DC_NAME} - Global Catalog</name>
              <type>DEPENDENT</type>
              <key>ad.dc.is_gc[{#DC_HOST}]</key>
              <delay>0</delay>
              <history>7d</history>
              <value_type>UNSIGNED</value_type>
              <preprocessing>
                <step>
                  <type>JSONPATH</type>
                  <parameters>
                    <parameter>$.domain_controllers[?(@.hostname=='{#DC_HOST}')].is_gc.first()</parameter>
                  </parameters>
                </step>
                <step>
                  <type>BOOL_TO_DECIMAL</type>
                  <parameters/>
                </step>
              </preprocessing>
              <master_item>
                <key>ad.monitor.data</key>
              </master_item>
            </item_prototype>
            <item_prototype>
              <uuid>dc5ef0eb4abe4b45ae9d4a8065adce8e</uuid>
              <name>DC {#DC_NAME} - OS Version</name>
              <type>DEPENDENT</type>
              <key>ad.dc.os_version[{#DC_HOST}]</key>
              <delay>0</delay>
              <history>7d</history>
              <value_type>TEXT</value_type>
              <preprocessing>
                <step>
                  <type>JSONPATH</type>
                  <parameters>
                    <parameter>$.domain_controllers[?(@.hostname=='{#DC_HOST}')].os_version.first()</parameter>
                  </parameters>
                </step>
              </preprocessing>
              <master_item>
                <key>ad.monitor.data</key>
              </master_item>
            </item_prototype>
          </item_prototypes>
        </discovery_rule>
        <discovery_rule>
          <uuid>8d5b3c02b31046f794244af0a0431fc7</uuid>
          <name>Discovery - Core Services</name>
          <type>DEPENDENT</type>
          <key>ad.discovery.services</key>
          <delay>0</delay>
          <preprocessing>
            <step>
              <type>JAVASCRIPT</type>
              <parameters>
                <parameter>var data = JSON.parse(value).services;
var out = [];
for (var key in data) { out.push({"{#SERVICE}": key}); }
return JSON.stringify(out);</parameter>
              </parameters>
            </step>
          </preprocessing>
          <master_item>
            <key>ad.monitor.data</key>
          </master_item>
          <item_prototypes>
            <item_prototype>
              <uuid>86ad2d1f3cf943509b8e329ef6aa3e3b</uuid>
              <name>Service Status - {#SERVICE}</name>
              <type>DEPENDENT</type>
              <key>ad.service.status[{#SERVICE}]</key>
              <delay>0</delay>
              <history>7d</history>
              <value_type>TEXT</value_type>
              <preprocessing>
                <step>
                  <type>JSONPATH</type>
                  <parameters>
                    <parameter>$.services.{#SERVICE}</parameter>
                  </parameters>
                </step>
              </preprocessing>
              <master_item>
                <key>ad.monitor.data</key>
              </master_item>
              <trigger_prototypes>
                <trigger_prototype>
                  <uuid>ac44e702a30e4788bfc32f14856cb567</uuid>
                  <expression>find(/AD Health Monitoring/ad.service.status[{#SERVICE}],,"like","Running")=0</expression>
                  <name>AD Service {#SERVICE} is not running on {HOST.NAME}</name>
                  <priority>HIGH</priority>
                </trigger_prototype>
              </trigger_prototypes>
            </item_prototype>
          </item_prototypes>
        </discovery_rule>
      </discovery_rules>
