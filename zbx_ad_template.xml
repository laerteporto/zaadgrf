  <templates>
    <template>
      <uuid>cee57701c39549808cac7863222cfe68</uuid>
      <template>AD Health Monitoring</template>
      <name>AD Health Monitoring</name>
      <description>Template para coleta de metricas operacionais do Active Directory via script PowerShell (ad_monitor.ps1) executado pelo Zabbix Agent. Cobre health score, servicos criticos, replicacao, usuarios, computadores e eventos de seguranca/DNS/Directory Service.</description>
      <groups>
        <group>
          <name>Templates/Applications</name>
        </group>
      </groups>
      <items>
        <item>
          <uuid>67181d630b4c4bc4a20704a0b1cf1db7</uuid>
          <name>AD Monitor - Raw JSON</name>
          <type>ZABBIX_PASSIVE</type>
          <key>ad.monitor.data</key>
          <delay>5m</delay>
          <history>2d</history>
          <trends>0</trends>
          <value_type>TEXT</value_type>
          <description>Executa o UserParameter ad.monitor.data (ad_monitor.ps1) e retorna o JSON completo. Item mestre para todos os itens dependentes deste template.</description>
          <tags>
            <tag>
              <tag>component</tag>
              <value>active-directory</value>
            </tag>
          </tags>
        </item>
        <item>
          <uuid>ff4ae576194f4ec7a4ec4ede50d0e589</uuid>
          <name>AD Health Score</name>
          <type>DEPENDENT</type>
          <key>ad.health_score</key>
          <delay>0</delay>
          <history>7d</history>
          <trends>365d</trends>
          <value_type>UNSIGNED</value_type>
          <preprocessing>
            <step>
              <type>JSONPATH</type>
              <parameters>
                <parameter>$.ad_health_score</parameter>
              </parameters>
            </step>
          </preprocessing>
          <master_item>
            <key>ad.monitor.data</key>
          </master_item>
          <tags>
            <tag>
              <tag>component</tag>
              <value>active-directory</value>
            </tag>
          </tags>
          <triggers>
            <trigger>
              <uuid>16af15b90a4649939daacefd0c86cc00</uuid>
              <expression>last(/AD Health Monitoring/ad.health_score)&lt;70</expression>
              <name>AD Health Score critico (&lt;70) em {HOST.NAME}</name>
              <priority>HIGH</priority>
              <description>Health score do Active Directory abaixo do limite aceitavel.</description>
            </trigger>
            <trigger>
              <uuid>d2d1f923526040b1aceef01f3599f7cd</uuid>
              <expression>last(/AD Health Monitoring/ad.health_score)&lt;85 and last(/AD Health Monitoring/ad.health_score)&gt;=70</expression>
              <name>AD Health Score em alerta (&lt;85) em {HOST.NAME}</name>
              <priority>WARNING</priority>
            </trigger>
          </triggers>
        </item>
